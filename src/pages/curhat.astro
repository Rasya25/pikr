---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Ruang Curhat">
    <div class="stack gap-12">
        <header class="hero">
            <h1 class="title">Ruang Curhat</h1>
            <p class="tagline">Ceritakan perasaanmu tentang ayahmu di sini. Semua ceritamu akan dijaga kerahasiaannya.</p>
        </header>

        <form id="curhat-form" class="curhat-form stack gap-6">
            <div class="form-group">
                <label for="initials">Inisial dan Kota</label>
                <input type="text" id="initials" name="initials" placeholder="Contoh: AR, Jakarta" required />
            </div>
            <div class="form-group">
                <label for="question1">1. Ayahku itu seperti?</label>
                <textarea id="question1" name="question1" rows="5" placeholder="Contoh: Ayahku adalah orang yang pekerja keras, tapi jarang punya waktu untukku..." required></textarea>
            </div>

            <div class="form-group">
                <label for="question2">2. Aku ingin ayahku seperti?</label>
                <textarea id="question2" name="question2" rows="5" placeholder="Contoh: Aku ingin ayahku lebih sering menanyakan kabarku dan mendengarkan ceritaku..." required></textarea>
            </div>

            <div class="cta-container">
                <button type="submit" class="submit-button">
                    Kirim Curhat
                </button>
            </div>
        </form>
    </div>
</BaseLayout>

<script>
    function setupCurhatForm() {
        console.log("Mencoba menyambungkan formulir...");
        const form = document.getElementById('curhat-form') as HTMLFormElement | null;

        if (form) {
            if (form.dataset.listenerAttached) {
                console.log("Listener sudah ada.");
                return;
            }
            console.log("Formulir ditemukan, menambahkan event listener.");
            form.dataset.listenerAttached = 'true';

            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                console.log("Formulir dikirim!");

                const submitButton = form.querySelector('.submit-button') as HTMLButtonElement | null;
                if (submitButton) submitButton.disabled = true;

                const formData = new FormData(form);
                try {
                    const response = await fetch('/api/curhat', {
                        method: 'POST',
                        body: formData
                    });

                    if (response.ok) {
                        console.log("Pengiriman berhasil.");
                        alert('Terima kasih telah berbagi cerita. Tetap semangat, ya!');
                        window.location.href = '/';
                    } else {
                        const errorData = await response.json();
                        console.error("Pengiriman gagal:", errorData.message);
                        alert('Gagal mengirim curhat: ' + errorData.message);
                    }
                } catch (error) {
                    console.error("Terjadi error pada jaringan:", error);
                    alert('Gagal mengirim curhat. Periksa koneksi internet Anda.');
                } finally {
                    if (submitButton) submitButton.disabled = false;
                }
            });
        } else {
            console.error("Formulir curhat tidak ditemukan!");
        }
    }

    document.addEventListener('astro:page-load', setupCurhatForm);
    setupCurhatForm();
</script>

<style>
    /* ... Gaya lain tidak berubah ... */
    .hero {
        text-align: center;
        padding: 2rem 1rem;
    }

    .title {
        font-size: clamp(2.5rem, 8vw, 3.5rem);
        color: var(--gray-0);
        margin-bottom: 0.5rem;
    }

    .tagline {
        font-size: clamp(1rem, 4vw, 1.15rem);
        color: var(--gray-300);
        max-width: 60ch;
        margin: 0 auto;
    }

    .curhat-form {
        max-width: 800px;
        width: 90%;
        margin: 0 auto;
        padding: clamp(1.5rem, 5vw, 2.5rem);
        background: var(--gradient-subtle);
        border: 1px solid var(--gray-800);
        border-radius: 1.5rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .form-group label {
        font-size: var(--text-lg);
        color: var(--gray-100);
    }

    .form-group input,
    .form-group textarea {
        width: 100%;
        padding: 1rem;
        font-size: var(--text-sm);
        background-color: var(--gray-900);
        border: 1px solid var(--gray-700);
        border-radius: 0.75rem;
        color: var(--gray-200);
        resize: vertical;
    }

    .form-group input:focus,
    .form-group textarea:focus {
        outline: none;
        border-color: var(--accent-regular);
    }

    .cta-container {
        display: flex;
        justify-content: flex-end;
        margin-top: 1rem;
    }

    .submit-button {
        display: inline-block;
        padding: 0.8rem 2rem;
        border-radius: 999px;
        background-image: var(--gradient-accent-orange);
        color: var(--gray-900);
        font-weight: 600;
        text-decoration: none;
        border: none;
        cursor: pointer;
    }
</style>
