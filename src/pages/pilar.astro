---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import Grid from '../components/Grid.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import CallToAction from '../components/CallToAction.astro';
import Icon from '../components/Icon.astro';

const projects = (await getCollection('maren')).filter(project => 
    project.data.tags.includes('Mental Health')
);

---

<BaseLayout>
	<div class="stack gap-20 lg:gap-48">
		<main class="wrapper stack gap-20 lg:gap-48">
			<section class="section with-background">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>PILAR: Pusat Inspirasi & Laku Remaja</h3>
					<p>Karena ketiadaan bukan berarti kehilangan masa depan. PILAR hadir sebagai pondasi bagi remaja untuk berdamai dengan luka, membangun resiliensi, dan tumbuh menjadi pribadi yang utuh meski tanpa figur ayah.</p>
				</header>

				<div class="gallery">
					<Grid variant="offset">
						{
							projects.map((project) => (
								<li>
									<PortfolioPreview project={project} />
								</li>
							))
						}
					</Grid>
				</div>
			</section>

			<section class="section with-background layout-curhat">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>Ruang Curhat: Fatherless</h3>
				</header>
				<div class="curhat-content">
					<h4>Apa itu <em>Fatherless</em>?</h4>
					<p>
						<em>Fatherless</em> adalah kondisi di mana seorang anak tumbuh tanpa kehadiran atau peran seorang ayah dalam kehidupannya. Ini bukan hanya tentang ketiadaan fisik, tetapi juga bisa berupa ketiadaan peran emosional dan psikologis.
					</p>
					<h4>Kondisi di Realita</h4>
					<p>Beberapa contoh situasi yang dapat menyebabkan kondisi <em>fatherless</em>:</p>
					<ul>
						<li>Perceraian orang tua yang menyebabkan anak tinggal terpisah dari ayah.</li>
						<li>Ayah yang bekerja di lokasi yang jauh dan jarang berinteraksi dengan anak.</li>
						<li>Ayah yang ada secara fisik namun tidak terlibat secara emosional dalam pengasuhan (<em>emotional absence</em>).</li>
						<li>Kehilangan ayah karena meninggal dunia.</li>
					</ul>
					<h4>Dampaknya</h4>
					<p>
						Ketiadaan figur ayah dapat memberikan dampak signifikan pada perkembangan anak, seperti kesulitan dalam menemukan identitas diri, masalah dalam mengelola emosi, tantangan dalam membangun hubungan yang sehat, dan menurunnya rasa percaya diri.
					</p>
				</div>
				<div class="cta">
					<CallToAction href="/curhat/">
						Confess about my father
						<Icon icon="arrow-right" size="1.2em" />
					</CallToAction>
				</div>
			</section>

			<section class="section with-background layout-cta">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>Tes MBTI</h3>
					<p>Cari tahu tipe kepribadianmu melalui tes MBTI.</p>
				</header>
				<div class="cta">
					<CallToAction href="https://www.16personalities.com/id/tes-kepribadian" target="_blank">
						Mulai Tes MBTI
						<Icon icon="arrow-right" size="1.2em" />
					</CallToAction>
				</div>
			</section>

			<section class="section with-background layout-cta">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>Games Kuis</h3>
					<p>Seberapa dekat kamu dengan ayahmu?</p>
				</header>
				<div class="cta">
					<CallToAction href="/kuis-ayah/" variant="secondary">
						Mulai Kuis
						<Icon icon="arrow-right" size="1.2em" />
					</CallToAction>
				</div>
			</section>

			<section class="section with-background bg-variant">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>Video Edukasi</h3>
					<p>Tonton video-video edukasi pilihan dari kami.</p>
				</header>
				<div class="video-gallery">
					<div class="video-container">
						<iframe src="https://www.youtube.com/embed/dQw4w9WgXcQ" title="YouTube video player" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
					</div>
				<div class="video-gallery">
					<div class="video-container">
						<iframe src="https://www.youtube.com/embed/dQw4w9WgXcQ" title="YouTube video player" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
					</div>
				</div>
			</section>
		</main>
	</div>
</BaseLayout>

<style>
	.section {
		display: grid;
		gap: 2rem;
	}

	.with-background {
		position: relative;
	}

	.with-background::before {
		--hero-bg: var(--bg-image-subtle-2);
		content: '';
		position: absolute;
		pointer-events: none;
		left: 50%;
		width: 100vw;
		aspect-ratio: calc(2.25 / var(--bg-scale));
		top: 0;
		transform: translateY(-75%) translateX(-50%);
		background: url('/assets/backgrounds/noise.png') top center/220px repeat, var(--hero-bg) center center / var(--bg-gradient-size) no-repeat, var(--gray-999);
		background-blend-mode: overlay, normal, normal, normal;
		mix-blend-mode: var(--bg-blend-mode);
		z-index: -1;
	}

	.with-background.bg-variant::before {
		--hero-bg: var(--bg-image-subtle-1);
	}

	.section-header {
		justify-self: center;
		text-align: center;
		max-width: 50ch;
	}

	.section-header h3 {
		font-size: clamp(1.75rem, 5vw, 2.5rem);
	}

	.curhat-content {
		background: var(--gradient-subtle);
		padding: clamp(1.5rem, 4vw, 2rem);
		border-radius: 1.5rem;
		color: var(--gray-200);
		border: 1px solid var(--gray-800);
	}

	.curhat-content h4 {
		font-size: clamp(1.1rem, 3vw, 1.25rem);
		color: var(--gray-0);
		margin-bottom: 0.75rem;
	}

	.curhat-content p,
	.curhat-content ul {
		font-size: var(--text-sm);
		line-height: 1.7;
		margin-bottom: 1rem;
	}

	.curhat-content ul {
		list-style-position: inside;
		padding-left: 0.5rem;
	}

	.curhat-content li {
		margin-bottom: 0.5rem;
	}

	.video-gallery {
		max-width: 800px;
		margin: 0 auto;
		width: 100%;
	}

	.video-container {
		position: relative;
		width: 100%;
		padding-top: 56.25%; /* 16:9 Aspect Ratio */
	}

	.video-container iframe {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		border: 0;
	}

	@media (min-width: 50em) {
		.section {
			grid-template-columns: repeat(4, 1fr);
			align-items: start;
			gap: 2rem 1.5rem;
		}

		.section > :is(.gallery, .video-gallery, .section-header) {
			grid-column: 1 / -1;
		}

		.layout-cta .section-header {
			grid-column: 1 / 4;
			text-align: left;
			justify-self: start;
		}

		.layout-cta .cta {
			grid-column: 4 / -1;
			align-self: center;
		}

		.layout-curhat .curhat-content {
			grid-column: 1 / -1;
		}

		.layout-curhat .cta {
			grid-column: 1 / -1;
			justify-self: center;
		}
	}
</style>
