---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import Grid from '../components/Grid.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import CallToAction from '../components/CallToAction.astro';
import Icon from '../components/Icon.astro';

const projects = (await getCollection('maren')).filter(project => 
    project.data.tags.includes('Mental Health')
);

---

<BaseLayout>
	<div class="stack gap-20 lg:gap-48">
		<main class="wrapper stack gap-20 lg:gap-48">
			<section class="section with-background">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>PILAR: Pusat Inspirasi & Laku Remaja</h3>
					<p>Karena ketiadaan bukan berarti kehilangan masa depan. PILAR hadir sebagai pondasi bagi remaja untuk berdamai dengan luka, membangun resiliensi, dan tumbuh menjadi pribadi yang utuh meski tanpa figur ayah.</p>
				</header>

				<div class="gallery">
					<Grid variant="offset">
						{
							projects.map((project) => (
								<li>
									<PortfolioPreview project={project} />
								</li>
							))
						}
					</Grid>
				</div>
			</section>

			<section class="section with-background layout-curhat">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>PILAR: Ruang Curhat</h3>
				</header>
				<div class="curhat-content">
					<h4>Apa itu <em>PILAR</em>?</h4>
					<p>
						Kepanjangan dari  <em>PILAR</em> adalah Pusat Inspirasi & Laku Remaja. Website ini bertujuan untuk mengurangi angka <em>Fatherless</em> di Indonesia, dan mengurangi angka  depresi akibat orang tua.
					</p>
					<p>Dengan memanfaatkan era digital saat ini, remaja pasti sering banget menggunakan media sosial, maka dari itu, Pik-R Inscada merancang Website Interaktif ini, untuk bisa memutus rantai stigma melalui fitur-fitur yang ada di Website PILAR. Kebanyakan remaja tidak punya "someone to talk", dan akhirnya dipendam sendiri, dan akan menimbulkan bahaya bagi kesehatan, dengan adanya fitur curhat, remaja merasa sangat terbantu, dan bisa memunculkan rasa percaya diri mereka melalui fitur curhat tersebut.</p>
					<h4>Peran Penting <em>PILAR</em>:</h4>
					<p>Beberapa contoh peran penting dari <em>pilar</em>:</p>
					<ul>
						<li>Menguatkan pondasi mental remaja yang "kehilangan peran ayah".</li>
						<li>Menjadi tempat cerita ter-aman bagi remaja.</li>
						<li>Membantu menjadi pribadi yang utuh meski tanpa figur ayah.</li>
						<li>Membantu remaja untuk bisa mengambil keputusan atau menentukan arah/tujuan bagi masa depannya.</li>
					</ul>
					<p>
						Yukk, curhatin sekarang, dan privasi kalian tetap aman sentosa.
					</p>
				</div>
				<div class="cta">
					<CallToAction href="/curhat/">
						Confess about my father
						<Icon icon="arrow-right" size="1.2em" />
					</CallToAction>
				</div>
			</section>

			<section class="section with-background layout-cta">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>Tes MBTI</h3>
					<p>Cari tahu tipe kepribadianmu melalui tes MBTI.</p>
				</header>
				<div class="cta">
					<CallToAction href="https://www.16personalities.com/id/tes-kepribadian" target="_blank">
						Mulai Tes MBTI
						<Icon icon="arrow-right" size="1.2em" />
					</CallToAction>
				</div>
			</section>

			<section class="section with-background layout-cta">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>Games Kuis</h3>
					<p>Seberapa dekat kamu dengan ayahmu?</p>
				</header>
				<div class="cta">
					<CallToAction href="/kuis-ayah/" variant="secondary">
						Mulai Kuis
						<Icon icon="arrow-right" size="1.2em" />
					</CallToAction>
				</div>
			</section>

			<section class="section with-background bg-variant">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>Video Edukasi</h3>
					<p>Tonton video-video edukasi pilihan dari kami.</p>
				</header>
				<div class="video-gallery">
					<div class="video-container">
						<iframe src="https://www.youtube.com/embed/TSEOIZyyZD4" title="YouTube video player" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
					</div>
				<div class="video-gallery">
					<div class="video-container">
						<iframe src="https://www.youtube.com/embed/WD-hQ_1FYPw" title="YouTube video player" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
					</div>
				<div class="video-gallery">
					<div class="video-container">
						<iframe src="https://www.youtube.com/embed/_50igeHW7vw" title="YouTube video player" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
					</div>
				<div class="video-gallery">
					<div class="video-container">
						<iframe src="https://www.youtube.com/embed/rkZl2gsLUp4" title="YouTube video player" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
					</div>
				</div>
			</section>
		</main>
	</div>
</BaseLayout>

<style>
	.section {
		display: grid;
		gap: 2rem;
	}

	.with-background {
		position: relative;
	}

	.with-background::before {
		--hero-bg: var(--bg-image-subtle-2);
		content: '';
		position: absolute;
		pointer-events: none;
		left: 50%;
		width: 100vw;
		aspect-ratio: calc(2.25 / var(--bg-scale));
		top: 0;
		transform: translateY(-75%) translateX(-50%);
		background: url('/assets/backgrounds/noise.png') top center/220px repeat, var(--hero-bg) center center / var(--bg-gradient-size) no-repeat, var(--gray-999);
		background-blend-mode: overlay, normal, normal, normal;
		mix-blend-mode: var(--bg-blend-mode);
		z-index: -1;
	}

	.with-background.bg-variant::before {
		--hero-bg: var(--bg-image-subtle-1);
	}

	.section-header {
		justify-self: center;
		text-align: center;
		max-width: 50ch;
	}

	.section-header h3 {
		font-size: clamp(1.75rem, 5vw, 2.5rem);
	}

	.curhat-content {
		background: var(--gradient-subtle);
		padding: clamp(1.5rem, 4vw, 2rem);
		border-radius: 1.5rem;
		color: var(--gray-200);
		border: 1px solid var(--gray-800);
	}

	.curhat-content h4 {
		font-size: clamp(1.1rem, 3vw, 1.25rem);
		color: var(--gray-0);
		margin-bottom: 0.75rem;
	}

	.curhat-content p,
	.curhat-content ul {
		font-size: var(--text-sm);
		line-height: 1.7;
		margin-bottom: 1rem;
	}

	.curhat-content ul {
		list-style-position: inside;
		padding-left: 0.5rem;
	}

	.curhat-content li {
		margin-bottom: 0.5rem;
	}

	.video-gallery {
		max-width: 800px;
		margin: 0 auto;
		width: 100%;
	}

	.video-container {
		position: relative;
		width: 100%;
		padding-top: 56.25%; /* 16:9 Aspect Ratio */
	}

	.video-container iframe {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		border: 0;
	}

	@media (min-width: 50em) {
		.section {
			grid-template-columns: repeat(4, 1fr);
			align-items: start;
			gap: 2rem 1.5rem;
		}

		.section > :is(.gallery, .video-gallery, .section-header) {
			grid-column: 1 / -1;
		}

		.layout-cta .section-header {
			grid-column: 1 / 4;
			text-align: left;
			justify-self: start;
		}

		.layout-cta .cta {
			grid-column: 4 / -1;
			align-self: center;
		}

		.layout-curhat .curhat-content {
			grid-column: 1 / -1;
		}

		.layout-curhat .cta {
			grid-column: 1 / -1;
			justify-self: center;
		}
	}
</style>
