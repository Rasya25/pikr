---
import BaseLayout from '../layouts/BaseLayout.astro';
import CallToAction from '../components/CallToAction.astro';
---

<BaseLayout title="Kuis Kedekatan dengan Ayah">
    <div class="stack gap-12">
        <header class="hero">
            <h1 class="title">Kuis: Seberapa Dekat Kamu dengan Ayahmu?</h1>
            <p class="tagline">Jawab pertanyaan berikut dengan jujur untuk melihat seberapa dalam hubunganmu dengan ayah.</p>
        </header>

        <form class="quiz-form stack gap-8">
            <div class="question-group stack gap-4">
                <p class="question">1. Seberapa sering kamu mengobrol santai dengan ayahmu dalam seminggu?</p>
                <div class="options stack gap-2">
                    <label><input type="radio" name="q1" value="a"> Hampir setiap hari</label>
                    <label><input type="radio" name="q1" value="b"> Beberapa kali seminggu</label>
                    <label><input type="radio" name="q1" value="c"> Jarang sekali</label>
                    <label><input type="radio" name="q1" value="d"> Tidak pernah</label>
                </div>
            </div>

            <div class="question-group stack gap-4">
                <p class="question">2. Apakah kamu merasa nyaman membicarakan masalah pribadimu dengan ayah?</p>
                <div class="options stack gap-2">
                    <label><input type="radio" name="q2" value="a"> Sangat nyaman</label>
                    <label><input type="radio" name="q2" value="b"> Cukup nyaman</label>
                    <label><input type="radio" name="q2" value="c"> Sedikit tidak nyaman</label>
                    <label><input type="radio" name="q2" value="d"> Sangat tidak nyaman</label>
                </div>
            </div>

            <div class="question-group stack gap-4">
                <p class="question">3. Apa kegiatan yang paling sering kamu lakukan bersama ayah?</p>
                <div class="options stack gap-2">
                    <label><input type="radio" name="q3" value="a"> Olahraga atau hobi bersama</label>
                    <label><input type="radio" name="q3" value="b"> Menonton film atau acara TV</label>
                    <label><input type="radio" name="q3" value="c"> Makan bersama</label>
                    <label><input type="radio" name="q3" value="d"> Tidak ada kegiatan spesifik</label>
                </div>
            </div>

            <div class="question-group stack gap-4">
                <p class="question">4. Ketika kamu butuh nasihat, apakah ayahmu orang pertama yang kamu tuju?</p>
                <div class="options stack gap-2">
                    <label><input type="radio" name="q4" value="a"> Ya, selalu</label>
                    <label><input type="radio" name="q4" value="b"> Sering, tapi tidak selalu</label>
                    <label><input type="radio" name="q4" value="c"> Jarang</label>
                    <label><input type="radio" name="q4" value="d"> Tidak pernah</label>
                </div>
            </div>

            <div class="cta-container">
                <button type="submit" class="submit-btn">Lihat Hasil</button>
            </div>
        </form>
    </div>

    <!-- Result Modal -->
    <div id="result-modal" class="modal-overlay" style="display: none;">
        <div class="modal-content">
            <h2 id="modal-title">Hasil Kuis</h2>
            <p id="modal-score"></p>
            <p id="modal-text"></p>
            <button id="modal-close-btn">Tutup</button>
        </div>
    </div>
</BaseLayout>

<script>
    const form = document.querySelector('.quiz-form');
    const modal = document.getElementById('result-modal');
    const modalScore = document.getElementById('modal-score');
    const modalText = document.getElementById('modal-text');
    const modalCloseBtn = document.getElementById('modal-close-btn');

    if (form instanceof HTMLFormElement && modal && modalScore && modalText && modalCloseBtn) {
        form.addEventListener('submit', (event) => {
            event.preventDefault();

            const formData = new FormData(form);
            const answers = {
                q1: formData.get('q1'),
                q2: formData.get('q2'),
                q3: formData.get('q3'),
                q4: formData.get('q4'),
            };

            let score = 0;
            if (answers.q1 === 'a') score += 25;
            if (answers.q1 === 'b') score += 15;
            if (answers.q1 === 'c') score += 5;
            
            if (answers.q2 === 'a') score += 25;
            if (answers.q2 === 'b') score += 15;
            if (answers.q2 === 'c') score += 5;

            if (answers.q3 === 'a') score += 25;
            if (answers.q3 === 'b') score += 15;
            if (answers.q3 === 'c') score += 5;

            if (answers.q4 === 'a') score += 25;
            if (answers.q4 === 'b') score += 15;
            if (answers.q4 === 'c') score += 5;

            let resultText = '';
            if (score > 75) {
                resultText = 'Wow, hubunganmu dengan ayah sangat dekat! Pertahankan terus, ya!';
            } else if (score > 50) {
                resultText = 'Hubunganmu dengan ayah cukup baik. Terus tingkatkan kualitas komunikasimu, ya!';
            } else {
                resultText = 'Sepertinya ada sedikit jarak antara kamu dan ayah. Coba deh, luangkan waktu untuk ngobrol lebih sering.';
            }

            modalScore.textContent = `Skor kamu: ${score}`;
            modalText.textContent = resultText;
            modal.style.display = 'flex';
        });

        modalCloseBtn.addEventListener('click', () => {
            modal.style.display = 'none';
            window.location.href = '/pilar';
        });
    }
</script>

<style>
    .hero {
        text-align: center;
        padding: 2rem 1rem;
    }

    .title {
        font-size: clamp(2rem, 6vw, 3rem);
        color: var(--gray-0);
        margin-bottom: 0.5rem;
    }

    .tagline {
        font-size: clamp(1rem, 4vw, 1.2rem);
        color: var(--gray-300);
        max-width: 60ch;
        margin: 0 auto;
    }

    .quiz-form {
        max-width: 800px;
        margin: 0 auto;
        width: 90%;
        background: var(--gradient-subtle);
        border: 1px solid var(--gray-800);
        border-radius: 1.5rem;
        padding: clamp(1.5rem, 5vw, 2.5rem);
    }

    .question {
        font-size: var(--text-lg);
        color: var(--gray-100);
        font-weight: 500;
    }

    .options label {
        display: block;
        padding: 0.75rem 1rem;
        background-color: var(--gray-900);
        border: 1px solid var(--gray-700);
        border-radius: 0.75rem;
        cursor: pointer;
        transition: background-color 0.2s, border-color 0.2s;
    }

    .options label:hover {
        background-color: var(--gray-800);
    }
    
    .options input[type="radio"] {
        margin-right: 0.75rem;
        accent-color: var(--accent-regular);
    }

    .cta-container {
        display: flex;
        justify-content: flex-end;
        margin-top: 1rem;
    }

    .submit-btn {
        background-color: var(--accent-regular);
        color: var(--gray-0);
        border: none;
        padding: 0.75rem 1.5rem;
        border-radius: 0.5rem;
        cursor: pointer;
        transition: background-color 0.2s;
        font-weight: 500;
    }

    .submit-btn:hover {
        background-color: var(--accent-dark);
    }

    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.6);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 1000;
    }

    .modal-content {
        background: var(--gray-900);
        padding: 2rem;
        border-radius: 1rem;
        border: 1px solid var(--gray-700);
        width: 90%;
        max-width: 500px;
        text-align: center;
        color: var(--gray-100);
    }

    #modal-title {
        font-size: 1.5rem;
        font-weight: 600;
        margin-bottom: 1rem;
    }

    #modal-score {
        font-size: 1.2rem;
        margin-bottom: 0.5rem;
    }

    #modal-text {
        margin-bottom: 1.5rem;
    }

    #modal-close-btn {
        background-color: var(--accent-regular);
        color: var(--gray-0);
        border: none;
        padding: 0.75rem 1.5rem;
        border-radius: 0.5rem;
        cursor: pointer;
        transition: background-color 0.2s;
    }

    #modal-close-btn:hover {
        background-color: var(--accent-dark);
    }
</style>
