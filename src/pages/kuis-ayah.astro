---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Kuis Kedekatan dengan Ayah">
    <div class="stack gap-12">
        <header class="hero">
            <h1 class="title">Kuis: Seberapa Dekat Kamu dengan Ayahmu?</h1>
            <p class="tagline">Jawab 10 pertanyaan berikut dengan jujur untuk melihat seberapa dalam hubunganmu dengan ayah.</p>
        </header>

        <form id="quiz-form" class="quiz-form stack gap-8">
            <!-- ... 10 questions from before ... -->
            <div class="question-group stack gap-4">
                <p class="question">1. Seberapa sering kamu mengobrol santai dengan ayahmu dalam seminggu?</p>
                <div class="options stack gap-2">
                    <label><input type="radio" name="q1" value="a" required> Hampir setiap hari</label>
                    <label><input type="radio" name="q1" value="b"> Beberapa kali seminggu</label>
                    <label><input type="radio" name="q1" value="c"> Jarang sekali</label>
                    <label><input type="radio" name="q1" value="d"> Tidak pernah</label>
                </div>
            </div>

            <div class="question-group stack gap-4">
                <p class="question">2. Apakah kamu merasa nyaman membicarakan masalah pribadimu dengan ayah?</p>
                <div class="options stack gap-2">
                    <label><input type="radio" name="q2" value="a" required> Sangat nyaman</label>
                    <label><input type="radio" name="q2" value="b"> Cukup nyaman</label>
                    <label><input type="radio" name="q2" value="c"> Sedikit tidak nyaman</label>
                    <label><input type="radio" name="q2" value="d"> Sangat tidak nyaman</label>
                </div>
            </div>

            <div class="question-group stack gap-4">
                <p class="question">3. Apa kegiatan yang paling sering kamu lakukan bersama ayah?</p>
                <div class="options stack gap-2">
                    <label><input type="radio" name="q3" value="a" required> Olahraga atau hobi bersama</label>
                    <label><input type="radio" name="q3" value="b"> Menonton film atau acara TV</label>
                    <label><input type="radio" name="q3" value="c"> Makan bersama</label>
                    <label><input type="radio" name="q3" value="d"> Tidak ada kegiatan spesifik</label>
                </div>
            </div>

            <div class="question-group stack gap-4">
                <p class="question">4. Ketika kamu butuh nasihat, apakah ayahmu orang pertama yang kamu tuju?</p>
                <div class="options stack gap-2">
                    <label><input type="radio" name="q4" value="a" required> Ya, selalu</label>
                    <label><input type="radio" name="q4" value="b"> Sering, tapi tidak selalu</label>
                    <label><input type="radio" name="q4" value="c"> Jarang</label>
                    <label><input type="radio" name="q4" value="d"> Tidak pernah</label>
                </div>
            </div>

            <div class="question-group stack gap-4">
                <p class="question">5. Seberapa tahu kamu tentang pekerjaan atau hobi ayahmu?</p>
                <div class="options stack gap-2">
                    <label><input type="radio" name="q5" value="a" required> Tahu dengan sangat detail</label>
                    <label><input type="radio" name="q5" value="b"> Tahu garis besarnya saja</label>
                    <label><input type="radio" name="q5" value="c"> Hanya tahu sedikit</label>
                    <label><input type="radio" name="q5" value="d"> Tidak tahu sama sekali</label>
                </div>
            </div>

            <div class="question-group stack gap-4">
                <p class="question">6. Apakah kamu pernah memberikan hadiah kepada ayahmu di luar hari ulang tahunnya?</p>
                <div class="options stack gap-2">
                    <label><input type="radio" name="q6" value="a" required> Ya, sering</label>
                    <label><input type="radio" name="q6" value="b"> Pernah beberapa kali</label>
                    <label><input type="radio" name="q6" value="c"> Mungkin sekali</label>
                    <label><input type="radio" name="q6" value="d"> Tidak pernah</label>
                </div>
            </div>

            <div class="question-group stack gap-4">
                <p class="question">7. Ketika ayahmu marah, apa yang biasanya kamu lakukan?</p>
                <div class="options stack gap-2">
                    <label><input type="radio" name="q7" value="a" required> Mencoba tenang dan membicarakannya baik-baik</label>
                    <label><input type="radio" name="q7" value="b"> Diam dan menunggu hingga marahnya reda</label>
                    <label><input type="radio" name="q7" value="c"> Menghindarinya</label>
                    <label><input type="radio" name="q7" value="d"> Ikut marah</label>
                </div>
            </div>

            <div class="question-group stack gap-4">
                <p class="question">8. Apakah kamu tahu makanan atau minuman favorit ayahmu?</p>
                <div class="options stack gap-2">
                    <label><input type="radio" name="q8" value="a" required> Ya, tahu persis dan sering menyiapkannya</label>
                    <label><input type="radio" name="q8" value="b"> Tahu, tapi jarang memperhatikannya</label>
                    <label><input type="radio" name="q8" value="c"> Hanya menebak-nebak</label>
                    <label><input type="radio" name="q8" value="d"> Tidak tahu</label>
                </div>
            </div>

            <div class="question-group stack gap-4">
                <p class="question">9. Seberapa sering kamu mengucapkan 'terima kasih' atau 'aku sayang kamu' kepada ayah?</p>
                <div class="options stack gap-2">
                    <label><input type="radio" name="q9" value="a" required> Cukup sering, hampir setiap minggu</label>
                    <label><input type="radio" name="q9" value="b"> Kadang-kadang di momen tertentu</label>
                    <label><input type="radio" name="q9" value="c"> Jarang sekali</label>
                    <label><input type="radio" name="q9" value="d"> Tidak pernah</label>
                </div>
            </div>

            <div class="question-group stack gap-4">
                <p class="question">10. Apakah kamu merasa ayahmu bangga padamu?</p>
                <div class="options stack gap-2">
                    <label><input type="radio" name="q10" value="a" required> Ya, saya yakin beliau bangga</label>
                    <label><input type="radio" name="q10" value="b"> Semoga saja, tapi tidak yakin</label>
                    <label><input type="radio" name="q10" value="c"> Sepertinya tidak</label>
                    <label><input type="radio" name="q10" value="d"> Saya rasa beliau kecewa</label>
                </div>
            </div>

            <div class="cta-container">
                <button type="submit" class="submit-btn">Lihat Hasil</button>
            </div>
        </form>
    </div>

    <!-- Result Modal -->
    <div id="result-modal" class="modal-overlay" style="display: none;">
        <div class="modal-content">
            <h2>Hasil Kuis</h2>
            <p id="modal-score"></p>
            <p id="modal-text"></p>
            <button id="modal-close-btn">Tutup</button>
        </div>
    </div>
</BaseLayout>

<script is:inline>
    function setupQuiz() {
        const form = document.getElementById('quiz-form');
        if (!form || form.dataset.initialized) return; // Keluar jika tidak ada form atau sudah diinisialisasi

        const modal = document.getElementById('result-modal');
        const modalScore = document.getElementById('modal-score');
        const modalText = document.getElementById('modal-text');
        const modalCloseBtn = document.getElementById('modal-close-btn');

        form.addEventListener('submit', (event) => {
            event.preventDefault();
            const formData = new FormData(form);
            let score = 0;
            for (let i = 1; i <= 10; i++) {
                const answer = formData.get('q' + i);
                if (!answer) {
                    alert('Harap jawab semua pertanyaan.');
                    return;
                }
                if (answer === 'a') score += 10;
                if (answer === 'b') score += 7;
                if (answer === 'c') score += 3;
            }

            let resultText = '';
            if (score > 80) {
                resultText = 'Wow, hubunganmu dengan ayah sangat dekat dan hangat! Pertahankan terus, ya!';
            } else if (score > 50) {
                resultText = 'Hubunganmu dengan ayah cukup baik. Masih ada ruang untuk lebih dekat. Coba tingkatkan komunikasimu!';
            } else {
                resultText = 'Sepertinya ada sedikit jarak antara kamu dan ayah. Ini kesempatan bagus untuk mulai membangun jembatan.';
            }

            modalScore.textContent = `Skor kamu: ${score} dari 100`;
            modalText.textContent = resultText;
            modal.style.display = 'flex';
        });

        modalCloseBtn.addEventListener('click', () => {
            modal.style.display = 'none';
            window.location.href = '/pilar';
        });

        form.dataset.initialized = 'true'; // Tandai bahwa event listener sudah ditambahkan
    }

    // Jalankan saat navigasi client-side
    document.addEventListener('astro:page-load', setupQuiz);
    // Jalankan saat hard refresh (jika astro:page-load tidak keburu)
    setupQuiz();
</script>

<style>
    .hero { text-align: center; padding: 2rem 1rem; }
    .title { font-size: clamp(2rem, 6vw, 3rem); color: var(--gray-0); margin-bottom: 0.5rem; }
    .tagline { font-size: clamp(1rem, 4vw, 1.2rem); color: var(--gray-300); max-width: 60ch; margin: 0 auto; }
    .quiz-form { max-width: 800px; margin: 0 auto; width: 90%; background: var(--gradient-subtle); border: 1px solid var(--gray-800); border-radius: 1.5rem; padding: clamp(1.5rem, 5vw, 2.5rem); }
    .question { font-size: var(--text-lg); color: var(--gray-100); font-weight: 500; }
    .options label { display: block; padding: 0.75rem 1rem; background-color: var(--gray-900); border: 1px solid var(--gray-700); border-radius: 0.75rem; cursor: pointer; transition: background-color 0.2s, border-color 0.2s; }
    .options label:hover { background-color: var(--gray-800); }
    .options input[type="radio"] { margin-right: 0.75rem; accent-color: var(--accent-regular); }
    .cta-container { display: flex; justify-content: flex-end; margin-top: 1rem; }
    .submit-btn { background-color: var(--accent-regular); color: var(--gray-0); border: none; padding: 0.75rem 1.5rem; border-radius: 0.5rem; cursor: pointer; transition: background-color 0.2s; font-weight: 500; }
    .submit-btn:hover { background-color: var(--accent-dark); }
    .modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.6); display: flex; justify-content: center; align-items: center; z-index: 1000; }
    .modal-content { background: var(--gray-900); padding: 2rem; border-radius: 1rem; border: 1px solid var(--gray-700); width: 90%; max-width: 500px; text-align: center; color: var(--gray-100); }
    .modal-content h2 { font-size: 1.5rem; font-weight: 600; margin-bottom: 1rem; }
    #modal-score { font-size: 1.2rem; margin-bottom: 0.5rem; }
    #modal-text { margin-bottom: 1.5rem; }
    #modal-close-btn { background-color: var(--accent-regular); color: var(--gray-0); border: none; padding: 0.75rem 1.5rem; border-radius: 0.5rem; cursor: pointer; transition: background-color 0.2s; }
    #modal-close-btn:hover { background-color: var(--accent-dark); }
</style>